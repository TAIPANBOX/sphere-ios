    "Export all data": {
      "localizations": {
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Експортувати всі дані"
          }
        }
      }
    },
    "Export all your data to a JSON file at any time from Settings. Nothing locks you in.": {
      "localizations": {
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Експортуйте всі свої дані у файл JSON у будь-який час із Налаштувань. Ніщо вас не утримує."
          }
        }
      }
    },
    "Export all your data to a file, or delete it, at any time from Settings.": {
